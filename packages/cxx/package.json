  "files": [
    "dist",
    "src"
  ],
  "homepage": "https://github.com/jk2908/cxx#readme",
  "keywords": [
    "react",
    "react19",
    "css",
    "css-in-js",
    "vite-plugin",
    "lightningcss",
    "vite"
